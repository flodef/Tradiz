# Editor to be able to open error directly from the browser
REACT_EDITOR=code

NEXT_PUBLIC_IS_DEV=true
NEXT_PUBLIC_USE_DIGICARTE=true
NEXT_PUBLIC_CLUSTER_ENDPOINT=https://solana-mainnet.rpc.extrnode.com
NEXT_PUBLIC_WEB_URL='https://mywebsite.fr'
# Shop identifier - also used as database name (e.g., 'annette', 'pauseiodee')
NEXT_PUBLIC_SHOP_ID=''

#Private Keys (DO NOT SHARE THOSE!!!)
# https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit#gid=xxxxxxxxxx
# Contains the id of the index spreadsheet if the app is used by many shops
INDEX_SPREADSHEET_ID=
# Contains the id of the shop spreadsheet if the app is used by only one shop
SHOP_SPREADSHEET_ID=
# https://console.cloud.google.com/apis/credentials?project=fims-353613
GOOGLE_API_KEY=

# Get those from your email provider
SMTP_HOST=smtp.mail.xxx.com
SMTP_PORT=465
SMTP_USER="contact@xxx.com"
SMTP_PASSWORD=
SMTP_FROM_EMAIL="postmaster@xxx.com"

# SQL DB
DB_HOST=
DB_USER=
DB_PASSWORD=
DB_NAME=

# POSTGRES DB (Neon)
# Get these from: https://console.neon.tech/app/projects
# Example: PG_HOST=ep-xxx-xxx.us-east-2.aws.neon.tech
# Note: Database name is automatically set from NEXT_PUBLIC_SHOP_ID (e.g., 'annette')
# The database contains three schemas: dc, dc_pos, dc_sys
PG_HOST=
PG_USER=
PG_PASSWORD=
